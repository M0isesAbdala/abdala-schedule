{
  "name": "abdala-schedule",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./types/index.d.ts",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "exports": {
    "import": "./dist/index.js",
    "require": "./dist/index.cjs",
    "types": "./types/index.d.ts"
  },
  "scripts": {
    "start": "bun run ./src/index.ts",
    "build": "tsc && bun build --target=node --format=esm --bundle ./src/index.ts --minify-whitespace --minify-identifiers --minify-syntax --outfile=dist/index.js && bun build --target=node --format=cjs --bundle ./src/index.ts --minify-whitespace --minify-identifiers --minify-syntax --outfile=dist/index.cjs"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}